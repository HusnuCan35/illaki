rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

      // ── Kullanıcı Profilleri ──────────────────────────────────────────────────
    match /users/{uid} {
      // Herkes okuyabilir (username göstermek için), sadece kendi profilini yazabilir
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // ── Arkadaşlar ve Davetler ──────────────────────────────────────────────
      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /friendRequests/{reqId} {
        allow read: if request.auth != null && (request.auth.uid == uid || request.auth.uid == reqId);
        allow create: if request.auth != null; // Herkes bana istek atabilir
        allow update, delete: if request.auth != null && (request.auth.uid == uid || request.auth.uid == reqId); // Gönderen de silebilir (iptal)
      }
      match /serverInvites/{invId} {
        allow read: if request.auth != null && (request.auth.uid == uid || request.auth.uid == invId);
        allow create: if request.auth != null; // Herkes davet atabilir
        allow update, delete: if request.auth != null && (request.auth.uid == uid || request.auth.uid == invId);
      }
    }

    // ── Kullanıcı ECDH Public Keyleri ─────────────────────────────────────────
    match /userKeys/{uid} {
      // Herkes okuyabilir (anahtar değişimi için), sadece kendi key'ini yazabilir
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Space (Oda) Dökümanları ───────────────────────────────────────────────
    match /spaces/{spaceId} {
      // Herhangi bir giriş yapmış kullanıcı okuyabilir (katılmak için)
      allow read: if request.auth != null;
      
      // Yeni space oluşturmak için giriş şart
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;
      
      // Güncelleme: sadece host veya kendi encryptedKeys entry'sini ekleyen üye
      allow update: if request.auth != null && (
        resource.data.hostUid == request.auth.uid ||
        // Üye kendi şifreli anahtarını yazabilir
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['encryptedKeys', 'memberCount', 'updatedAt'])
      );
      
      // Silme: sadece host
      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;

      // 💬 Eski Mesajlar (Geriye Dönük Uyumluluk) ────────────────────────────────
      match /messages/{messageId} {
        allow read, create, update, delete: if true; // Geriye dönük izinleri şimdilik açıyoruz (üretimde düzeltilmeli)
      }

      // 📺 Kanallar ─────────────────────────────────────────────────────────────
      match /channels/{channelId} {
        // Üyeler okuyabilir
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid));
        
        // Host veya admin/mod yetkili kişiler oluşturabilir, güncelleyebilir, silebilir
        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/spaces/$(spaceId)).data.hostUid == request.auth.uid ||
          get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid)).data.role in ['admin', 'mod']
        );
        
        // 💬 Yeni Mesajlar (Kanalların Altında) ────────────────────────────────
        match /messages/{messageId} {
          allow read, write: if true;
        }
      }

      // ── Müzik (Music Bot) ────────────────────────────────────────────────────
      match /music/{docId} {
        // Üyeler okuyabilir ve müzik durumunu güncelleyebilir
        allow read, write: if request.auth != null
          && exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid));
      }

      // ── Üyeler ───────────────────────────────────────────────────────────────
      match /members/{uid} {
        // Aynı space'deki üyeler VEYA kişinin kendisi görebilir (katılırken kontrol için)
        allow read: if request.auth != null && (
          request.auth.uid == uid ||
          exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid))
        );
        
        // Kendi üyeliğini oluşturabilir/güncelleyebilir
        // VEYA Host yetkileri değiştirebilir
        allow write: if request.auth != null && (
          request.auth.uid == uid ||
          get(/databases/$(database)/documents/spaces/$(spaceId)).data.hostUid == request.auth.uid
        );
        
        // Host herhangi bir üyeyi silebilir (kick)
        allow delete: if request.auth != null && (
          request.auth.uid == uid ||
          get(/databases/$(database)/documents/spaces/$(spaceId)).data.hostUid == request.auth.uid
        );
      }
    }
  }
}
